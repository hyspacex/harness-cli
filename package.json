{
  "name": "harness-cli",
  "version": "0.3.0",
  "type": "module",
  "license": "Apache-2.0",
  "description": "CLI harness for long-running app development with Claude Agent SDK or Codex App Server.",
  "bin": {
    "harness": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "harness": "npm run build --silent && node ./dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0"
  }
}
