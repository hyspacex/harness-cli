{
  "name": "harness-cli",
  "version": "0.3.0",
  "type": "module",
  "license": "Apache-2.0",
  "description": "CLI harness for long-running app development with Claude Agent SDK or Codex App Server.",
  "bin": {
    "harness": "./dist/cli.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:harness": "tsc -p tsconfig.json",
    "harness": "npm run build:harness --silent && node ./dist/cli.js",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "parse-gtfs": "node scripts/parse-gtfs.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "maplibre-gl": "^5.22.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "csv-parse": "^6.2.1",
    "typescript": "^5.7.0",
    "unzipper": "^0.12.3",
    "vite": "^8.0.3"
  }
}
